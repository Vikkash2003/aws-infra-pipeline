# Terraform state files — never commit these
.terraform/
*.tfstate
*.tfstate.backup
*.tfstate.lock.info
.terraform.lock.hcl

# Terraform variable files that may contain secrets
*.tfvars
!example.tfvars

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash log files
crash.log
crash.*.log

# SSH Keys — never commit private keys
*.pem
*.key

# OS generated files
.DS_Store
.DS_Store?
._*
Thumbs.db

# Editor directories
.vscode/settings.json
.idea/
